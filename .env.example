# Where the browser sends API requests (relative path → Next.js proxies them).
# Keeps requests same-origin so SameSite=Lax cookies from the backend work.
NEXT_PUBLIC_API_BASE_URL=/api

# The actual backend that Next.js's server-side proxy forwards to.
# Server-only — does NOT need a NEXT_PUBLIC_ prefix.
# For local backend: http://localhost:3003
BACKEND_API_URL=https://api.secondjobsearch.com
